#
# Backend environment example for Smart Phone Recommender
# Copy this file to `.env` and fill in your real values.
#

# MongoDB connection string (keep this secret, do not commit .env)
# Example for Atlas:
# mongodb+srv://USER:PASSWORD@cluster0.yourid.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGO_URI=

# Database and collection names (we keep the defaults you approved)
MONGO_DB=phone_recommender
PHONES_COLLECTION=phones

# Simple shared secret for /update-database admin endpoint
API_SECRET_TOKEN=change-me

# Copy to .env and fill in. Do not commit .env to version control.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGO_DB=phone_recommender
PHONES_COLLECTION=phones
API_SECRET_TOKEN=change-me
